generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]

  @@index([name])
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  password          String?
  inviteToken       String?        @unique
  inviteTokenExpiry DateTime?
  name              String
  role              UserRole       @default(EMPLOYEE)
  avatar            String?
  phone             String?
  joiningDate       DateTime       @default(now())
  isActive          Boolean        @default(true)
  departmentId      String?
  managerId         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  companyId         String
  ceoSchedules      CeoSchedule[]
  managedDepartment Department?    @relation("DepartmentHead")
  leaveBalances     LeaveBalance[]
  approvedLeaves    LeaveRequest[] @relation("ApproverRequests")
  leaveRequests     LeaveRequest[] @relation("EmployeeRequests")
  notifications     Notification[]
  company           Company        @relation(fields: [companyId], references: [id])
  department        Department?    @relation("DepartmentMembers", fields: [departmentId], references: [id])
  manager           User?          @relation("ManagerSubordinates", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates      User[]         @relation("ManagerSubordinates")

  @@index([departmentId])
  @@index([managerId])
  @@index([email])
  @@index([companyId])
}

model Department {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  headId      String?      @unique
  parentId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  head        User?        @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  members     User[]       @relation("DepartmentMembers")
}

model LeaveType {
  id                 String         @id @default(cuid())
  name               String         @unique
  description        String?
  defaultDaysPerYear Float
  maxCarryOver       Float          @default(0)
  requiresApproval   Boolean        @default(true)
  requiresDocument   Boolean        @default(false)
  maxConsecutiveDays Int?
  isPaid             Boolean        @default(true)
  isActive           Boolean        @default(true)
  color              String         @default("#4F46E5")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(cuid())
  userId      String
  leaveTypeId String
  year        Int
  allocated   Float
  used        Float     @default(0)
  pending     Float     @default(0)
  carriedOver Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([userId])
  @@index([year])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  totalDays    Float
  dayType      DayType     @default(FULL_DAY)
  reason       String
  documentUrl  String?
  status       LeaveStatus @default(PENDING)
  approverId   String?
  approverNote String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  approver     User?       @relation("ApproverRequests", fields: [approverId], references: [id], onDelete: SetNull)
  leaveType    LeaveType   @relation(fields: [leaveTypeId], references: [id])
  user         User        @relation("EmployeeRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([leaveTypeId])
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  year        Int
  isOptional  Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, name])
  @@index([year])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model CeoSchedule {
  id          String   @id @default(cuid())
  userId      String
  startDate   DateTime
  endDate     DateTime
  eventType   String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate, endDate])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  CEO
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DayType {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}
