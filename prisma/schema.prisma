generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  CEO
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DayType {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]

  @@index([name])
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  password          String
  name              String
  role              UserRole       @default(EMPLOYEE)
  avatar            String?
  phone             String?
  joiningDate       DateTime       @default(now())
  isActive          Boolean        @default(true)

  companyId         String
  company           Company        @relation(fields: [companyId], references: [id])

  departmentId      String?
  department        Department?    @relation("DepartmentMembers", fields: [departmentId], references: [id])

  managerId         String?
  manager           User?          @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates      User[]         @relation("ManagerSubordinates")

  managedDepartment Department?    @relation("DepartmentHead")

  leaveRequests     LeaveRequest[] @relation("EmployeeRequests")
  approvedLeaves    LeaveRequest[] @relation("ApproverRequests")
  leaveBalances     LeaveBalance[]
  notifications     Notification[]
  ceoSchedules      CeoSchedule[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([departmentId])
  @@index([managerId])
  @@index([email])
  @@index([companyId])
}

model Department {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?

  headId      String?      @unique
  head        User?        @relation("DepartmentHead", fields: [headId], references: [id])

  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")

  members     User[]       @relation("DepartmentMembers")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model LeaveType {
  id                 String         @id @default(cuid())
  name               String         @unique
  description        String?
  defaultDaysPerYear Float
  maxCarryOver       Float          @default(0)
  requiresApproval   Boolean        @default(true)
  requiresDocument   Boolean        @default(false)
  maxConsecutiveDays Int?
  isPaid             Boolean        @default(true)
  isActive           Boolean        @default(true)
  color              String         @default("#4F46E5")

  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model LeaveBalance {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int

  allocated   Float
  used        Float     @default(0)
  pending     Float     @default(0)
  carriedOver Float     @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, leaveTypeId, year])
  @@index([userId])
  @@index([year])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("EmployeeRequests", fields: [userId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType   @relation(fields: [leaveTypeId], references: [id])

  startDate    DateTime
  endDate      DateTime
  totalDays    Float
  dayType      DayType     @default(FULL_DAY)
  reason       String
  documentUrl  String?

  status       LeaveStatus @default(PENDING)

  approverId   String?
  approver     User?       @relation("ApproverRequests", fields: [approverId], references: [id])
  approverNote String?
  reviewedAt   DateTime?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([leaveTypeId])
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  year        Int
  isOptional  Boolean  @default(false)
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, name])
  @@index([year])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  linkUrl   String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model CeoSchedule {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  eventType   String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([startDate, endDate])
}